+    def _get_missing_required_args(
+        usable_cls: type[LLMUsable],
+        args: dict[str, Any],
+    ) -> list[str]:
+        """根据 schema 检查工具调用是否缺少必填参数。"""
+        try:
+            schema = usable_cls.to_schema()
+        except Exception:
+            return []
+
+        function_schema = schema.get("function", {})
+        parameters = function_schema.get("parameters", {})
+        required_args = parameters.get("required", [])
+        if not isinstance(required_args, list):
+            return []
+
+        missing: list[str] = []
+        for name in required_args:
+            if not isinstance(name, str):
+                continue
+            if name not in args or args.get(name) is None:
+                missing.append(name)
+        return missing
